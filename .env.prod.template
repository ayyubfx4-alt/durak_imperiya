# =============================================================================
# .env.prod.template — Production environment variable template
#
# SETUP:
#   cp .env.prod.template .env.prod
#   # Fill in all REQUIRED values below
#   # NEVER commit .env.prod to git (it's in .gitignore)
#
# WARNING: Committing secrets to git is a critical security breach.
#   Use this template only. Real values go in .env.prod (gitignored).
# =============================================================================

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=durak_prod
POSTGRES_USER=durak
POSTGRES_PASSWORD=REQUIRED__change_this_to_a_strong_password_32chars+

# Database URL (used by backend directly)
DATABASE_URL=postgres://durak:REQUIRED__change_this@postgres:5432/durak_prod

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=REQUIRED__change_this_to_a_strong_password_24chars+
REDIS_URL=redis://:REQUIRED__change_this@redis:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
# CRITICAL: Must be a cryptographically random 64+ character string.
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REQUIRED__generate_with_crypto_randomBytes_64

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
CORS_ORIGIN=https://yourdomain.com
PUBLIC_APP_URL=https://yourdomain.com
TURN_REALM=durakimperia
TURN_USER=REQUIRED__turn_user
TURN_PASSWORD=REQUIRED__turn_password
VOICE_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"},{"urls":["turn:yourdomain.com:3478?transport=udp","turn:yourdomain.com:3478?transport=tcp"],"username":"REQUIRED__turn_user","credential":"REQUIRED__turn_password"}]

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_PIN=REQUIRED__change_from_default_2202
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=REQUIRED__strong_admin_password

# ── Stripe Payments ───────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_REQUIRED__your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_REQUIRED__your_webhook_signing_secret

# ── Google Play IAP ───────────────────────────────────────────────────────────
# Service account JSON (one line, escaped): from Google Play Console
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
GOOGLE_PLAY_PACKAGE_NAME=com.yourcompany.durakimperia

# ── App Store IAP ─────────────────────────────────────────────────────────────
# From: App Store Connect > My Apps > App Information > Shared Secret
APPLE_SHARED_SECRET=REQUIRED__your_apple_shared_secret

# ── Telegram Bot ─────────────────────────────────────────────────────────────
# From: @BotFather on Telegram
TELEGRAM_BOT_TOKEN=REQUIRED__your_telegram_bot_token

# ── Sentry Error Tracking (optional) ─────────────────────────────────────────
# From: https://sentry.io — create a Node.js project
# Leave empty to disable Sentry
SENTRY_DSN=

# ── Feature flags ─────────────────────────────────────────────────────────────
# NEVER set these to 1 in production
ALLOW_DEV_PURCHASES=0
ALLOW_MOCK_IAP=0
