# Durak Imperia production environment template
# Copy this to the real server as .env and fill real values.

NODE_ENV=production
PORT=4000
DATABASE_URL=postgres://durak:CHANGE_ME@postgres:5432/durak
REDIS_URL=redis://redis:6379
CORS_ORIGIN=https://YOUR_DOMAIN
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_SECRET
ADMIN_BOOTSTRAP_EMAIL=admin@durak.local
ADMIN_BOOTSTRAP_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# App / Play Market
RELEASE_PLATFORMS=android
TURN_REALM=durakimperia
TURN_USER=CHANGE_ME_TURN_USER
TURN_PASSWORD=CHANGE_ME_TURN_PASSWORD
VOICE_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"},{"urls":["turn:YOUR_DOMAIN:3478?transport=udp","turn:YOUR_DOMAIN:3478?transport=tcp"],"username":"CHANGE_ME_TURN_USER","credential":"CHANGE_ME_TURN_PASSWORD"}]
PUBLIC_APP_URL=https://YOUR_DOMAIN
PRIVACY_POLICY_URL=https://YOUR_DOMAIN/privacy.html
GOOGLE_PLAY_PACKAGE_NAME=com.durakimperia.game
ANDROID_TARGET_SDK=36
GOOGLE_PLAY_BILLING_MAJOR=8
ANDROID_RELEASE_KEYSTORE_READY=0

# Economy
MIN_BET=100
MAX_BET=1000000
AD_BONUS_DOLLARS=800
AD_COOLDOWN_HOURS=6
AD_BALANCE_CAP=50000
ALLOW_DEV_PURCHASES=0
TOURNAMENT_ENTRY_GOLD=35
TOURNAMENT_PRIZE_FIRST_GOLD=150
TOURNAMENT_PRIZE_SECOND_GOLD=75
TOURNAMENT_PRIZE_THIRD_GOLD=35
BOT_POOL_SIZE=100

# AdMob: rewarded video only.
# Values must be real AdMob production ids, not Google's sample ids.
# Callback URL in AdMob rewarded unit: ${PUBLIC_APP_URL}/api/admob/ssv
ADMOB_ANDROID_APP_ID=
ADMOB_REWARDED_ANDROID_ID=
ADMOB_IOS_APP_ID=
ADMOB_REWARDED_IOS_ID=
ADMOB_HALAL_CATEGORIES_BLOCKED=0

# Billing / IAP
GOOGLE_SERVICE_ACCOUNT_JSON=
APPLE_SHARED_SECRET=

# Premium prices are intentionally blank until approved.
PREMIUM_MONTHLY_USD=
PREMIUM_QUARTERLY_USD=
PREMIUM_YEARLY_USD=
PREMIUM_PRICES_APPROVED=0

# Server decision
# Keep USE_NODE_BACKEND_ONLY=1 if this Node backend is the official multiplayer backend.
# Set GDEVELOP_SILVER_ACTIVE=1 only if the project is actually deployed through GDevelop services.
USE_NODE_BACKEND_ONLY=1
GDEVELOP_SILVER_ACTIVE=0
