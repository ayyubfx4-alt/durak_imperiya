TURN_REALM=durakimperia
TURN_USER=CHANGE_ME_TURN_USER
TURN_PASSWORD=CHANGE_ME_TURN_PASSWORD
VOICE_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"},{"urls":["turn:YOUR_DOMAIN:3478?transport=udp","turn:YOUR_DOMAIN:3478?transport=tcp"],"username":"CHANGE_ME_TURN_USER","credential":"CHANGE_ME_TURN_PASSWORD"}]

JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_SECRET
JWT_EXPIRES_IN=7d
ADMIN_BOOTSTRAP_EMAIL=admin@YOUR_DOMAIN
ADMIN_BOOTSTRAP_PASSWORD=CHANGE_ME_STRONG_PASSWORD
