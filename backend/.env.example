NODE_ENV=development
PORT=4000
JWT_SECRET=replace-with-strong-random-secret
JWT_EXPIRES_IN=7d
DATABASE_URL=postgres://durak:durak@localhost:5432/durak
CORS_ORIGIN=http://localhost:8080
ADMIN_BOOTSTRAP_EMAIL=admin@durak.local
ADMIN_BOOTSTRAP_PASSWORD=changeme

# Durak Online v4 economy (TOR §4).
MIN_BET=100
MAX_BET=1000000
AD_BONUS_DOLLARS=800
AD_COOLDOWN_HOURS=6
AD_BALANCE_CAP=1000
REFERRAL_BONUS_DOLLARS=5
REFERRAL_GAMES_REQUIRED=3
BOT_FILL_TIMEOUT_MS=30000
TURN_TIMEOUT_MS=30000
BOT_POOL_SIZE=100

# Tournaments (TOR §5) — Gold Coin entry and prizes.
TOURNAMENT_ENTRY_GOLD=35
TOURNAMENT_PRIZE_FIRST_GOLD=150
TOURNAMENT_PRIZE_SECOND_GOLD=75
TOURNAMENT_PRIZE_THIRD_GOLD=35

# Stripe (leave empty to disable real payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost:8080/#/shop?status=success
STRIPE_CANCEL_URL=http://localhost:8080/#/shop?status=cancelled

# Production release readiness
