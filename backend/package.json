{
  "name": "durak-online-backend",
  "version": "1.1.0",
  "description": "Durak Online — real-time multiplayer card game backend (Node.js + Socket.IO + PostgreSQL + Redis)",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "migrate": "node src/scripts/migrate.js",
    "seed": "node src/scripts/seed.js",
    "test": "node --test tests/*.test.js",
    "test:shop-live": "node src/scripts/liveShopEconomyCheck.js",
    "test:profile-live": "node src/scripts/liveProfileCheck.js",
    "lint": "eslint src tests"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "redis": "^4.7.0",
    "socket.io": "^4.8.1",
    "stripe": "^22.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "eslint": "^9.16.0"
  }
}
