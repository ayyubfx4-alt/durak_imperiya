{
  "name": "durak-online-native",
  "version": "1.0.0",
  "description": "Capacitor native shell for Durak Imperia (Android + iOS) — wraps the game with AdMob, Google Play Billing, and Push.",
  "private": true,
  "scripts": {
    "sync": "cap sync",
    "open:android": "cap open android",
    "open:ios": "cap open ios",
    "build:android": "cap sync android && cd android && ./gradlew bundleRelease",
    "build:apk": "cap sync android && cd android && ./gradlew assembleRelease",
    "run:android": "cap run android",
    "run:ios": "cap run ios",
    "assets": "capacitor-assets generate"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.0.2",
    "@capacitor/core": "^8.3.4",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/push-notifications": "^8.1.1",
    "@capacitor/status-bar": "^8.0.2",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor-community/admob": "^8.0.0",
    "capacitor-plugin-safe-area": "^5.0.0",
    "cordova-plugin-purchase": "^13.16.1"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.4"
  }
}
