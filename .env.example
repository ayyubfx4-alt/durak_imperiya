# Durak Imperia production environment example.
# Copy this file to .env on the server and replace every CHANGE_ME value.
# Never commit real secrets, bot tokens, payment keys, or private keys.

# Runtime mode and HTTP port used by the Node.js backend.
NODE_ENV=production
PORT=4000

# JWT_SECRET signs user login tokens. Use a long random value:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_ME_96_CHAR_RANDOM_HEX
JWT_EXPIRES_IN=7d

# PostgreSQL connection used by the backend and migrations.
DATABASE_URL=postgres://durak:CHANGE_ME_DB_PASSWORD@postgres:5432/durak
PGSSLMODE=disable
DB_POOL_MAX=20
POSTGRES_USER=durak
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=durak

# Public HTTPS origins. CORS_ORIGIN should be the exact web-client URL.
CORS_ORIGIN=https://your-domain.example
PUBLIC_APP_URL=https://your-domain.example
PUBLIC_BASE_URL=https://your-domain.example
PRIVACY_POLICY_URL=https://your-domain.example/privacy.html

# Redis enables Socket.IO scaling and shared presence between backend replicas.
REDIS_URL=redis://redis:6379
INSTANCE_ID=durak-be-1
INSTANCE_PREFIX=durak-be
INSTANCE_COUNT=4
PRESENCE_TTL_S=60

# Admin bootstrap account created/updated by the seed script.
ADMIN_BOOTSTRAP_EMAIL=admin@durak.local
ADMIN_BOOTSTRAP_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD
ADMIN_PIN=CHANGE_ME_PRIVATE_PIN

# Stripe keys. Leave blank to disable Stripe until live keys are ready.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLIC_KEY=
STRIPE_SUCCESS_URL=https://your-domain.example/#/shop?status=success
STRIPE_CANCEL_URL=https://your-domain.example/#/shop?status=cancelled

# Firebase service account and web app config.
# FIREBASE_PRIVATE_KEY should keep newlines escaped as \n when stored in .env.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
GOOGLE_CLIENT_ID=

# Telegram bot and mini-app URLs.
TELEGRAM_BOT_TOKEN=
TELEGRAM_GAME_URL=https://your-domain.example/
TELEGRAM_ADMIN_URL=https://your-admin-domain.example/login
TELEGRAM_OWNER_ID=8324791195
TELEGRAM_ADMIN_IDS=8324791195,8396560736
TELEGRAM_HERO_IMAGE_URL=https://your-domain.example/images/login-imperia-bg.jpg
TELEGRAM_PLAY_MARKET_URL=https://play.google.com/store/apps/details?id=com.durakimperia.game
TELEGRAM_STARS_ENABLED=1
TELEGRAM_BOT_POLLING_ENABLED=1
TELEGRAM_BOT_INSTANCE_ID=durak-be-1
TELEGRAM_DROP_PENDING_UPDATES=0

# Game economy. AD_BALANCE_CAP can be raised/lowered without code changes.
MIN_BET=100
MAX_BET=1000000
AD_BONUS_DOLLARS=800
AD_COOLDOWN_HOURS=6
AD_BALANCE_CAP=50000
ALLOW_DEV_PURCHASES=0
ALLOW_MOCK_IAP=0
REFERRAL_BONUS_DOLLARS=5
REFERRAL_DOWNSTREAM_BONUS_DOLLARS=1
REFERRAL_GAMES_REQUIRED=3
BOT_FILL_TIMEOUT_MS=30000
MM_WAIT_MS=8000
FRIEND_COIN_GIFT_DAILY_LIMIT=50000

# Tournament defaults.
TOURNAMENT_ENTRY_GOLD=35
TOURNAMENT_PRIZE_FIRST_GOLD=150
TOURNAMENT_PRIZE_SECOND_GOLD=75
TOURNAMENT_PRIZE_THIRD_GOLD=35
BOT_POOL_SIZE=100

# Google Play / mobile build settings.
RELEASE_PLATFORMS=android

# WebRTC ICE servers for voice chat. TURN is required for reliable voice across
# strict mobile networks and many carrier NATs.
TURN_REALM=durakimperia
TURN_USER=CHANGE_ME_TURN_USER
TURN_PASSWORD=CHANGE_ME_TURN_PASSWORD
VOICE_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"},{"urls":["turn:your-domain.example:3478?transport=udp","turn:your-domain.example:3478?transport=tcp"],"username":"CHANGE_ME_TURN_USER","credential":"CHANGE_ME_TURN_PASSWORD"}]
GOOGLE_PLAY_PACKAGE_NAME=com.durakimperia.game
GOOGLE_SERVICE_ACCOUNT_JSON=
APPLE_SHARED_SECRET=
ANDROID_TARGET_SDK=36
GOOGLE_PLAY_BILLING_MAJOR=8
ANDROID_RELEASE_KEYSTORE_READY=0

# AdMob rewarded ads.
ADMOB_ANDROID_APP_ID=
ADMOB_IOS_APP_ID=
ADMOB_REWARDED_ANDROID_ID=
ADMOB_REWARDED_IOS_ID=
ADMOB_HALAL_CATEGORIES_BLOCKED=0

# Premium subscriptions. Keep blank until prices are approved.
PREMIUM_MONTHLY_USD=
PREMIUM_QUARTERLY_USD=
PREMIUM_YEARLY_USD=
PREMIUM_PRICES_APPROVED=0

# Architecture flags.
USE_NODE_BACKEND_ONLY=1
GDEVELOP_SILVER_ACTIVE=0
