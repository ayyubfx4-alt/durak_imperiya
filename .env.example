# ── Server ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
# JWT_SECRET is MANDATORY in production. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# docker-compose refuses to start without it.
JWT_SECRET=replace-with-strong-random-secret
JWT_EXPIRES_IN=7d

# ── PostgreSQL ─────────────────────────────────────────────────────────────
DATABASE_URL=postgres://durak:durak@postgres:5432/durak
POSTGRES_USER=durak
POSTGRES_PASSWORD=durak
POSTGRES_DB=durak

# ── CORS ───────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:8080

# ── Firebase / Google Auth ─────────────────────────────────────────────────
# 1. Go to Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=          # paste the "private_key" field from the JSON (newlines as \n)

# 2. Web client Firebase config (from Project Settings → Your apps)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# 3. OAuth client ID (for Google Sign-In on web)
GOOGLE_CLIENT_ID=

# ── FCM Push Notifications ─────────────────────────────────────────────────
# FCM v1 uses the same Firebase service account JSON as Google Play/Firebase.
# Required for push: FIREBASE_PROJECT_ID + GOOGLE_SERVICE_ACCOUNT_JSON.

# ── In-App Purchases ──────────────────────────────────────────────────────
# Google Play: service account JSON (stringify the whole JSON file, or use a path)
GOOGLE_PLAY_PACKAGE_NAME=com.yourcompany.durak
GOOGLE_SERVICE_ACCOUNT_JSON=

# Apple App Store: shared secret from App Store Connect → My Apps → In-App Purchases
APPLE_SHARED_SECRET=

# ── AdMob ─────────────────────────────────────────────────────────────────
# Android App ID from AdMob Console (e.g. ca-app-pub-XXXXXXXXXXXXXXXX~XXXXXXXXXX)
ADMOB_ANDROID_APP_ID=
ADMOB_IOS_APP_ID=
# Rewarded video ad unit IDs
ADMOB_REWARDED_ANDROID_ID=
ADMOB_REWARDED_IOS_ID=
ADMOB_HALAL_CATEGORIES_BLOCKED=0

# ── Admin bootstrap ────────────────────────────────────────────────────────
ADMIN_BOOTSTRAP_EMAIL=admin@durak.local
ADMIN_BOOTSTRAP_PASSWORD=changeme
ADMIN_PIN=replace-with-private-admin-pin

# ── Game settings ──────────────────────────────────────────────────────────
MIN_BET=5
DAILY_BONUS_COINS=10
PREMIUM_DAILY_BONUS_COINS=20
AD_BONUS_DOLLARS=800
AD_COOLDOWN_HOURS=6
REFERRAL_BONUS_COINS=5
REFERRAL_GAMES_REQUIRED=3
BOT_FILL_TIMEOUT_MS=30000

# ── Web client base URL ────────────────────────────────────────────────────
PUBLIC_BASE_URL=http://localhost:8080
RELEASE_PLATFORMS=android
PUBLIC_APP_URL=
PRIVACY_POLICY_URL=
PREMIUM_MONTHLY_USD=
PREMIUM_QUARTERLY_USD=
PREMIUM_YEARLY_USD=
PREMIUM_PRICES_APPROVED=0
GDEVELOP_SILVER_ACTIVE=0
USE_NODE_BACKEND_ONLY=1
ANDROID_RELEASE_KEYSTORE_READY=0
ADMIN_UPLOAD_DIR=
FRIEND_COIN_GIFT_DAILY_LIMIT=50000
ADMOB_SSV_KEYS_URL=https://www.gstatic.com/admob/reward/verifier-keys.json
ADMOB_SSV_KEYS_TTL_MS=21600000
ADMOB_SSV_MAX_AGE_MS=86400000

# Telegram bot
# Create/rotate token via @BotFather. Do not commit real tokens.
# Telegram WebApp buttons require a public HTTPS URL in production.
TELEGRAM_BOT_TOKEN=
TELEGRAM_GAME_URL=https://your-domain.example/
TELEGRAM_ADMIN_URL=https://your-admin-domain.example/login
TELEGRAM_OWNER_ID=8324791195
TELEGRAM_ADMIN_IDS=8324791195,8396560736
TELEGRAM_HERO_IMAGE_URL=https://your-domain.example/images/login-imperia-bg.jpg
TELEGRAM_PLAY_MARKET_URL=https://play.google.com/store/apps/details?id=com.durakimperia.game
TELEGRAM_STARS_ENABLED=1
TELEGRAM_BOT_POLLING_ENABLED=1
TELEGRAM_BOT_INSTANCE_ID=durak-be-1
TELEGRAM_DROP_PENDING_UPDATES=0

# ── Stripe (optional — legacy real-money path) ────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost:8080/#/shop?status=success
STRIPE_CANCEL_URL=http://localhost:8080/#/shop?status=cancelled

# ── PRO v4.1: Redis (Socket.IO horizontal scaling) ────────────────────────
# When set, enables multi-instance scaling via @socket.io/redis-adapter.
# Leave empty for single-process mode (legacy v4 behaviour).
REDIS_URL=redis://redis:6379
PRESENCE_TTL_S=60

# ── PRO v4.1: Scaling identity ────────────────────────────────────────────
INSTANCE_ID=durak-be-1
INSTANCE_PREFIX=durak-be
INSTANCE_COUNT=1

# ── PRO v4.1: Capacitor / AdMob bridge (mobile only) ──────────────────────
# Real AdMob unit ids are passed to the WebView via:
#   window.__ADMOB_REWARDED_ID__ = 'ca-app-pub-XXXX/YYYY';
# (set on the home page before showRewardedAd() is called)
ALLOW_MOCK_IAP=0
